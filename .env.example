# Copy this file to the PROJECT ROOT as ".env" (not under .github/workflows).
#   cp .env.example .env
# Vite only reads .env from roadmap-app-2/ — restart "npm run dev" after changes.
#
# Data source: "local" = built-in dummy data, no external service (admin token: local-dev).
#              "remote" = use VITE_SHEETS_API_URL below.
# If unset, defaults to "remote" when VITE_SHEETS_API_URL is set, else "local".
VITE_DATA_SOURCE=local

# Optional: override the local-mode admin token (default "local-dev").
# VITE_LOCAL_ADMIN_TOKEN=

# Write token sent to Google Apps Script on add/edit/delete (remote mode).
# Must match the script's ADMIN_TOKEN Script Property (default "relias-2026").
VITE_ADMIN_TOKEN=relias-2026

# Remote backend URL (Google Apps Script today; Microsoft SharePoint/Excel endpoint later).
# Setup: see README.md
# Admin token (dev): roadmap-dev-2026
VITE_SHEETS_API_URL=

# Spreadsheet URL for "Google Sheets" link (shown when admin token is unlocked)
VITE_GOOGLE_SHEET_URL=
